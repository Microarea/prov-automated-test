# GWAM Authentication Credentials (REQUIRED)
GWAM_USER=your.username@example.com
GWAM_PASSWORD=your_password_here

# Test Environment (OPTIONAL - default: test)
# Values: dev, test, release, prod
TEST_ENV=test

# Test file path for single test execution (OPTIONAL)
# Example: TEST_FILE=tests/console/health.spec.ts
TEST_FILE=
